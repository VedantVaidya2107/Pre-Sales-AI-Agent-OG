# Gemini AI API Key (Required)
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Deepgram API Key (Required for Voice Discovery)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Server Port (default: 8000)
PORT=8000

# Frontend URL for CORS (default: http://localhost:5173 / 5174)
FRONTEND_URL=http://localhost:5174

# Email Configuration (optional — leave blank for simulated mode)
# Uses Gmail SMTP. Enable "App Passwords" in your Google account.
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_FROM_NUMBER=your_twilio_number

# Base URL for Webhooks
BASE_URL=https://your-tunnel-url.trycloudflare.com
