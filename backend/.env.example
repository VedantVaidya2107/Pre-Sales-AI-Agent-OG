# Gemini AI API Key (Required)
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port (default: 3001)
PORT=3001

# Frontend URL for CORS (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Email Configuration (optional — leave blank for simulated mode)
# Uses Gmail SMTP. Enable "App Passwords" in your Google account.
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# --- LiveKit & SIP Configuration (for AI Voice Agent) ---
# Sign up at https://cloud.livekit.io/
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Groq (Faster LLM for real-time voice)
# Sign up at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key

# Vobiz / SIP Trunking (Telephony)
VOBIZ_SIP_TRUNK_ID=your_trunk_id
VOBIZ_SIP_DOMAIN=your_sip_domain
VOBIZ_USERNAME=your_sip_username
VOBIZ_PASSWORD=your_sip_password
VOBIZ_OUTBOUND_NUMBER=your_outbound_caller_id
DEFAULT_TRANSFER_NUMBER=your_forwarding_number
